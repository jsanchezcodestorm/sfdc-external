{
  "query": {
    "object": "Account",
    "fields": ["Id", "Name", "Type", "Industry", "OwnerId", "CreatedDate"],
    "where": [
      { "field": "Id", "operator": "=", "value": "{{id}}" }
    ],
    "limit": 1
  },
  "titleTemplate": "{{Name || Id}}",
  "fallbackTitle": "Account Detail",
  "actions": [
    { "type": "edit", "label": "Edit" },
    { "type": "delete", "label": "Delete" }
  ],
  "sections": [
    "sections/main.json"
  ],
  "relatedLists": []
}
