{
  "id": "all",
  "label": "All Accounts",
  "default": true,
  "pageSize": 25,
  "query": {
    "object": "Account",
    "fields": ["Id", "Name", "Type", "Industry", "OwnerId", "CreatedDate"],
    "orderBy": [{ "field": "Name", "direction": "ASC" }]
  },
  "search": {
    "fields": ["Name", "Industry", "Type"],
    "minLength": 2
  },
  "columns": [
    { "field": "Name", "label": "Name" },
    { "field": "Type", "label": "Type" },
    { "field": "Industry", "label": "Industry" },
    { "field": "OwnerId", "label": "Owner" },
    { "field": "CreatedDate", "label": "Created" }
  ],
  "rowActions": [
    { "type": "edit", "label": "Edit" },
    { "type": "delete", "label": "Delete" }
  ]
}
