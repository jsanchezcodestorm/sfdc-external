generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum VisibilityRuleEffect {
  ALLOW
  DENY
}

enum VisibilityDecision {
  ALLOW
  DENY
}

enum VisibilityPolicyDefinitionCacheStatus {
  READY
  INVALID
}

enum ApplicationAuditStatus {
  PENDING
  SUCCESS
  FAILURE
}

enum AclResourceKind {
  REST
  ENTITY
  QUERY
  ROUTE
}

enum AclResourceAccessMode {
  DISABLED
  AUTHENTICATED
  PERMISSION_BOUND
}

enum AclResourceManagedBy {
  MANUAL
  SYSTEM
}

enum AclResourceSyncState {
  PRESENT
  STALE
}

enum SetupSalesforceMode {
  USERNAME_PASSWORD
  ACCESS_TOKEN
}

enum AuthProviderType {
  OIDC
  LOCAL
}

enum AppItemKind {
  HOME
  ENTITY
  CUSTOM_PAGE
  EXTERNAL_LINK
  REPORT
  DASHBOARD
}

enum ReportFolderAccessMode {
  PERSONAL
  SHARED
}

enum ReportShareMode {
  INHERIT
  RESTRICTED
  PERSONAL
}

enum ReportShareSubjectType {
  CONTACT
  PERMISSION
}

model VisibilityPolicyMeta {
  id            Int      @id @default(1)
  policyVersion BigInt   @default(1)
  updatedAt     DateTime @updatedAt

  @@map("policy_meta")
}

model VisibilityObjectPolicyVersion {
  objectApiName String   @id @db.VarChar(128)
  policyVersion BigInt   @default(1)
  updatedAt     DateTime @updatedAt

  @@map("object_policy_version")
}

model VisibilityCone {
  id          String                 @id @default(uuid()) @db.Uuid
  code        String                 @unique @db.VarChar(64)
  name        String                 @db.VarChar(128)
  priority    Int                    @default(0)
  active      Boolean                @default(true)
  updatedAt   DateTime               @updatedAt
  rules       VisibilityRule[]
  assignments VisibilityAssignment[]

  @@map("cones")
}

model VisibilityRule {
  id            String               @id @default(uuid()) @db.Uuid
  coneId        String               @db.Uuid
  objectApiName String               @db.VarChar(128)
  description   String?              @db.VarChar(512)
  effect        VisibilityRuleEffect
  conditionJson Json
  fieldsAllowed Json?
  fieldsDenied  Json?
  active        Boolean              @default(true)
  updatedAt     DateTime             @updatedAt
  cone          VisibilityCone       @relation(fields: [coneId], references: [id], onDelete: Cascade)

  @@index([objectApiName, active])
  @@map("rules")
}

model VisibilityAssignment {
  id             String         @id @default(uuid()) @db.Uuid
  coneId         String         @db.Uuid
  contactId      String?        @db.VarChar(128)
  permissionCode String?        @db.VarChar(80)
  recordType     String?        @db.VarChar(80)
  validFrom      DateTime?
  validTo        DateTime?
  updatedAt      DateTime       @updatedAt
  cone           VisibilityCone @relation(fields: [coneId], references: [id], onDelete: Cascade)

  @@index([contactId, permissionCode, recordType, validFrom, validTo])
  @@map("assignments")
}

model VisibilityPolicyDefinitionCache {
  objectApiName        String                              @db.VarChar(128)
  objectPolicyVersion  BigInt
  status               VisibilityPolicyDefinitionCacheStatus
  compiledDefinition   Json?
  invalidRuleId        String?                             @db.Uuid
  invalidRuleMessage   String?                             @db.VarChar(512)
  updatedAt            DateTime                            @updatedAt

  @@id([objectApiName, objectPolicyVersion])
  @@map("policy_definition_cache")
}

model VisibilityUserScopeCache {
  cacheKey          String   @id @db.VarChar(255)
  objectApiName     String   @db.VarChar(128)
  objectPolicyVersion BigInt
  compiledAllowPredicate String? @db.Text
  compiledDenyPredicate  String? @db.Text
  compiledPredicate String   @db.Text
  compiledFields    Json?
  deniedFields      Json?
  appliedCones      Json
  appliedRules      Json
  matchedAssignments Json
  expiresAt         DateTime
  updatedAt         DateTime @updatedAt

  @@index([objectApiName, objectPolicyVersion])
  @@index([expiresAt])
  @@map("user_scope_cache")
}

model VisibilityAuditLog {
  id                 BigInt             @id @default(autoincrement())
  requestId          String             @db.VarChar(64)
  createdAt          DateTime           @default(now())
  contactId          String             @db.VarChar(128)
  permissionsHash    String             @db.VarChar(128)
  recordType         String?            @db.VarChar(80)
  objectApiName      String             @db.VarChar(128)
  queryKind          String             @db.VarChar(64)
  baseWhereHash      String             @db.VarChar(128)
  finalWhereHash     String             @db.VarChar(128)
  appliedCones       Json
  appliedRules       Json
  decision           VisibilityDecision
  decisionReasonCode String             @db.VarChar(64)
  rowCount           Int
  durationMs         Int
  policyVersion      BigInt
  objectPolicyVersion BigInt

  @@index([createdAt])
  @@index([contactId, createdAt])
  @@index([objectApiName, createdAt])
  @@index([decisionReasonCode, createdAt])
  @@map("audit_log")
}

model SecurityAuditLog {
  id           BigInt             @id @default(autoincrement())
  requestId    String             @db.VarChar(64)
  createdAt    DateTime           @default(now())
  contactId    String?            @db.VarChar(128)
  endpoint     String             @db.VarChar(512)
  httpMethod   String             @db.VarChar(16)
  eventType    String             @db.VarChar(64)
  decision     VisibilityDecision
  reasonCode   String             @db.VarChar(64)
  ipHash       String             @db.VarChar(128)
  userAgentHash String            @db.VarChar(128)
  metadataJson Json?

  @@index([createdAt])
  @@index([requestId])
  @@index([contactId, createdAt])
  @@index([eventType, createdAt])
  @@index([reasonCode, createdAt])
  @@map("security_audit_log")
}

model ApplicationAuditLog {
  id            BigInt                 @id @default(autoincrement())
  requestId     String                 @db.VarChar(64)
  createdAt     DateTime               @default(now())
  completedAt   DateTime?
  contactId     String                 @db.VarChar(128)
  action        String                 @db.VarChar(64)
  targetType    String                 @db.VarChar(64)
  targetId      String                 @db.VarChar(128)
  objectApiName String?                @db.VarChar(128)
  recordId      String?                @db.VarChar(18)
  status        ApplicationAuditStatus
  payloadHash   String                 @db.VarChar(128)
  metadataJson  Json?
  resultJson    Json?
  errorCode     String?                @db.VarChar(128)

  @@index([createdAt])
  @@index([requestId])
  @@index([contactId, createdAt])
  @@index([action, createdAt])
  @@index([status, createdAt])
  @@index([targetType, createdAt])
  @@index([objectApiName, createdAt])
  @@map("application_audit_log")
}

model QueryAuditLog {
  id            BigInt                 @id @default(autoincrement())
  requestId     String                 @db.VarChar(64)
  createdAt     DateTime               @default(now())
  completedAt   DateTime?
  contactId     String                 @db.VarChar(128)
  queryKind     String                 @db.VarChar(64)
  targetId      String                 @db.VarChar(128)
  objectApiName String                 @db.VarChar(128)
  recordId      String?                @db.VarChar(18)
  status        ApplicationAuditStatus
  resolvedSoql  String                 @db.Text
  baseWhere     String                 @db.Text
  baseWhereHash String                 @db.VarChar(128)
  finalWhere    String                 @db.Text
  finalWhereHash String                @db.VarChar(128)
  rowCount      Int
  durationMs    Int
  errorCode     String?                @db.VarChar(128)
  metadataJson  Json?
  resultJson    Json?

  @@index([createdAt])
  @@index([requestId])
  @@index([contactId, createdAt])
  @@index([queryKind, createdAt])
  @@index([status, createdAt])
  @@index([targetId, createdAt])
  @@index([objectApiName, createdAt])
  @@index([recordId, createdAt])
  @@map("query_audit_log")
}

model SalesforceSObjectDescribeCache {
  cacheKey      String   @id @db.VarChar(64)
  cacheScope    String   @db.VarChar(512)
  objectApiName String   @db.VarChar(128)
  apiVersion    String   @db.VarChar(32)
  describeJson  Json
  payloadHash   String   @db.VarChar(64)
  fetchedAt     DateTime @default(now())
  expiresAt     DateTime
  updatedAt     DateTime @updatedAt

  @@index([cacheScope, objectApiName, apiVersion])
  @@index([expiresAt])
  @@map("salesforce_sobject_describe_cache")
}

model InstanceSetupRecord {
  id                         Int                 @id @default(1)
  siteName                   String              @db.VarChar(128)
  adminEmail                 String              @db.VarChar(320)
  salesforceMode             SetupSalesforceMode
  salesforceConfigEncrypted  String              @db.Text
  completedAt                DateTime
  createdAt                  DateTime            @default(now())
  updatedAt                  DateTime            @updatedAt

  @@map("instance_setup")
}

model AuthProviderAdminConfigRecord {
  providerId             String           @id @db.VarChar(64)
  type                   AuthProviderType
  label                  String?          @db.VarChar(128)
  enabled                Boolean          @default(true)
  sortOrder              Int              @default(0)
  configJson             Json?
  clientSecretEncrypted  String?          @db.Text
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt

  @@map("auth_provider_admin_configs")
}

model LocalCredentialRecord {
  contactId       String   @id @db.VarChar(128)
  username        String   @unique @db.VarChar(320)
  passwordHash    String   @db.Text
  enabled         Boolean  @default(true)
  failedAttempts  Int      @default(0)
  lockedUntil     DateTime?
  lastLoginAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([username])
  @@index([enabled, updatedAt])
  @@map("local_credentials")
}

model EntityQueryCursorCache {
  tokenHash          String   @id @db.VarChar(128)
  cursorKind         String   @db.VarChar(32)
  contactId          String   @db.VarChar(128)
  entityId           String   @db.VarChar(64)
  viewId             String?  @db.VarChar(64)
  relatedListId      String?  @db.VarChar(64)
  recordId           String?  @db.VarChar(18)
  searchTerm         String?  @db.VarChar(512)
  objectApiName      String   @db.VarChar(128)
  pageSize           Int
  totalSize          Int
  resolvedSoql       String   @db.Text
  baseWhere          String   @db.Text
  finalWhere         String   @db.Text
  queryFingerprint   String   @db.VarChar(128)
  sourceLocator      String?  @db.Text
  sourceRecordsJson  Json
  expiresAt          DateTime
  updatedAt          DateTime @updatedAt

  @@index([contactId, entityId, cursorKind])
  @@index([expiresAt])
  @@map("entity_query_cursor_cache")
}

model ReportQueryCursorCache {
  tokenHash        String   @id @db.VarChar(128)
  contactId        String   @db.VarChar(128)
  appId            String   @db.VarChar(64)
  reportId         String   @db.Uuid
  objectApiName    String   @db.VarChar(128)
  pageSize         Int
  totalSize        Int
  resolvedSoql     String   @db.Text
  baseWhere        String   @db.Text
  finalWhere       String   @db.Text
  queryFingerprint String   @db.VarChar(128)
  sourceLocator    String?  @db.Text
  sourceRecordsJson Json
  expiresAt        DateTime
  updatedAt        DateTime @updatedAt

  @@index([contactId, appId, reportId])
  @@index([expiresAt])
  @@map("report_query_cursor_cache")
}

model EntityConfigRecord {
  id             String                    @id @db.VarChar(64)
  objectApiName  String                    @db.VarChar(128)
  label          String                    @db.VarChar(128)
  description    String?                   @db.VarChar(512)
  navigationJson Json?
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt
  listConfig     EntityListConfigRecord?
  detailConfig   EntityDetailConfigRecord?
  formConfig     EntityFormConfigRecord?
  appItems       AppItemRecord[]

  @@map("entity_configs")
}

model EntityListConfigRecord {
  entityId          String                       @id @db.VarChar(64)
  title             String                       @db.VarChar(256)
  subtitle          String?                      @db.VarChar(512)
  primaryActionJson Json?
  createdAt         DateTime                     @default(now())
  updatedAt         DateTime                     @updatedAt
  entity            EntityConfigRecord           @relation(fields: [entityId], references: [id], onDelete: Cascade)
  views             EntityListViewConfigRecord[]

  @@map("entity_list_configs")
}

model EntityListViewConfigRecord {
  id                String                 @id @default(uuid()) @db.Uuid
  entityId          String                 @db.VarChar(64)
  sortOrder         Int
  viewId            String                 @db.VarChar(64)
  label             String                 @db.VarChar(256)
  description       String?                @db.VarChar(512)
  isDefault         Boolean                @default(false)
  pageSize          Int?
  queryJson         Json
  columnsJson       Json
  searchJson        Json?
  primaryActionJson Json?
  rowActionsJson    Json?
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  listConfig        EntityListConfigRecord @relation(fields: [entityId], references: [entityId], onDelete: Cascade)

  @@unique([entityId, viewId])
  @@index([entityId, sortOrder])
  @@map("entity_list_view_configs")
}

model EntityDetailConfigRecord {
  entityId       String                            @id @db.VarChar(64)
  queryJson      Json
  titleTemplate  String?                           @db.VarChar(512)
  fallbackTitle  String?                           @db.VarChar(256)
  subtitle       String?                           @db.VarChar(512)
  actionsJson    Json?
  pathStatusJson Json?
  createdAt      DateTime                          @default(now())
  updatedAt      DateTime                          @updatedAt
  entity         EntityConfigRecord                @relation(fields: [entityId], references: [id], onDelete: Cascade)
  sections       EntityDetailSectionConfigRecord[]
  relatedLists   EntityRelatedListConfigRecord[]

  @@map("entity_detail_configs")
}

model EntityDetailSectionConfigRecord {
  id           String                   @id @default(uuid()) @db.Uuid
  entityId     String                   @db.VarChar(64)
  sortOrder    Int
  title        String                   @db.VarChar(256)
  fieldsJson   Json
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt
  detailConfig EntityDetailConfigRecord @relation(fields: [entityId], references: [entityId], onDelete: Cascade)

  @@index([entityId, sortOrder])
  @@map("entity_detail_section_configs")
}

model EntityRelatedListConfigRecord {
  id             String                   @id @default(uuid()) @db.Uuid
  entityId       String                   @db.VarChar(64)
  sortOrder      Int
  relatedListId  String                   @db.VarChar(64)
  label          String                   @db.VarChar(256)
  description    String?                  @db.VarChar(512)
  queryJson      Json
  columnsJson    Json
  actionsJson    Json?
  rowActionsJson Json?
  emptyState     String?                  @db.VarChar(512)
  pageSize       Int?
  linkedEntityId String?                  @db.VarChar(64)
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt
  detailConfig   EntityDetailConfigRecord @relation(fields: [entityId], references: [entityId], onDelete: Cascade)

  @@unique([entityId, relatedListId])
  @@index([entityId, sortOrder])
  @@map("entity_related_list_configs")
}

model EntityFormConfigRecord {
  entityId    String                          @id @db.VarChar(64)
  createTitle String                          @db.VarChar(256)
  editTitle   String                          @db.VarChar(256)
  queryJson   Json
  subtitle    String?                         @db.VarChar(512)
  createdAt   DateTime                        @default(now())
  updatedAt   DateTime                        @updatedAt
  entity      EntityConfigRecord              @relation(fields: [entityId], references: [id], onDelete: Cascade)
  sections    EntityFormSectionConfigRecord[]

  @@map("entity_form_configs")
}

model EntityFormSectionConfigRecord {
  id         String                 @id @default(uuid()) @db.Uuid
  entityId   String                 @db.VarChar(64)
  sortOrder  Int
  title      String?                @db.VarChar(256)
  fieldsJson Json
  createdAt  DateTime               @default(now())
  updatedAt  DateTime               @updatedAt
  formConfig EntityFormConfigRecord @relation(fields: [entityId], references: [entityId], onDelete: Cascade)

  @@index([entityId, sortOrder])
  @@map("entity_form_section_configs")
}

model AppConfigRecord {
  id          String                        @id @db.VarChar(64)
  label       String                        @db.VarChar(128)
  description String?                       @db.VarChar(512)
  sortOrder   Int                           @default(0)
  createdAt   DateTime                      @default(now())
  updatedAt   DateTime                      @updatedAt
  items       AppItemRecord[]
  permissions AppPermissionAssignmentRecord[]
  reportFolders ReportFolderRecord[]
  reports     ReportDefinitionRecord[]
  dashboardFolders DashboardFolderRecord[]
  dashboards  DashboardDefinitionRecord[]

  @@index([sortOrder, label])
  @@map("app_configs")
}

model AppItemRecord {
  appId       String             @db.VarChar(64)
  itemId      String             @db.VarChar(64)
  kind        AppItemKind
  label       String             @db.VarChar(128)
  description String?            @db.VarChar(512)
  sortOrder   Int
  entityId    String?            @db.VarChar(64)
  resourceId  String?            @db.VarChar(128)
  configJson  Json?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  app         AppConfigRecord    @relation(fields: [appId], references: [id], onDelete: Cascade)
  entity      EntityConfigRecord? @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@id([appId, itemId])
  @@unique([appId, sortOrder])
  @@index([appId, kind, sortOrder])
  @@index([entityId])
  @@index([resourceId])
  @@map("app_item_records")
}

model AppPermissionAssignmentRecord {
  appId          String          @db.VarChar(64)
  permissionCode String          @db.VarChar(80)
  sortOrder      Int
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  app            AppConfigRecord @relation(fields: [appId], references: [id], onDelete: Cascade)

  @@id([appId, permissionCode])
  @@index([appId, sortOrder])
  @@index([permissionCode])
  @@map("app_permission_assignments")
}

model AclPermissionRecord {
  code        String                    @id @db.VarChar(80)
  label       String?                   @db.VarChar(128)
  description String?                   @db.VarChar(512)
  createdAt   DateTime                  @default(now())
  updatedAt   DateTime                  @updatedAt
  aliases     AclPermissionAliasRecord[]
  defaults    AclDefaultPermissionRecord[]
  resources   AclResourcePermissionRecord[]

  @@map("acl_permissions")
}

model AclPermissionAliasRecord {
  id             String              @id @default(uuid()) @db.Uuid
  permissionCode String              @db.VarChar(80)
  alias          String              @unique @db.VarChar(80)
  sortOrder      Int
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  permission     AclPermissionRecord @relation(fields: [permissionCode], references: [code], onDelete: Cascade)

  @@index([permissionCode, sortOrder])
  @@map("acl_permission_aliases")
}

model AclDefaultPermissionRecord {
  permissionCode String              @id @db.VarChar(80)
  sortOrder      Int
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  permission     AclPermissionRecord @relation(fields: [permissionCode], references: [code], onDelete: Restrict)

  @@index([sortOrder])
  @@map("acl_default_permissions")
}

model AclContactPermissionRecord {
  contactId      String   @db.VarChar(128)
  permissionCode String   @db.VarChar(80)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@id([contactId, permissionCode])
  @@index([contactId])
  @@index([permissionCode])
  @@map("acl_contact_permissions")
}

model AclResourceRecord {
  id          String                      @id @db.VarChar(128)
  type        AclResourceKind
  accessMode  AclResourceAccessMode       @default(AUTHENTICATED)
  managedBy   AclResourceManagedBy        @default(MANUAL)
  syncState   AclResourceSyncState        @default(PRESENT)
  sourceType  AclResourceKind?
  sourceRef   String?                     @db.VarChar(256)
  target      String?                     @db.VarChar(512)
  description String?                     @db.VarChar(512)
  createdAt   DateTime                    @default(now())
  updatedAt   DateTime                    @updatedAt
  permissions AclResourcePermissionRecord[]

  @@index([managedBy, syncState])
  @@map("acl_resources")
}

model AclResourcePermissionRecord {
  id             String              @id @default(uuid()) @db.Uuid
  resourceId      String              @db.VarChar(128)
  permissionCode  String              @db.VarChar(80)
  sortOrder       Int
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  resource        AclResourceRecord   @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  permission      AclPermissionRecord @relation(fields: [permissionCode], references: [code], onDelete: Restrict)

  @@unique([resourceId, permissionCode])
  @@index([resourceId, sortOrder])
  @@index([permissionCode])
  @@map("acl_resource_permissions")
}

model QueryTemplateRecord {
  id                String   @id @db.VarChar(64)
  objectApiName     String   @db.VarChar(128)
  description       String?  @db.VarChar(512)
  soql              String   @db.Text
  defaultParamsJson Json?
  maxLimit          Int?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("query_templates")
}

model ReportFolderRecord {
  id             String                 @id @default(uuid()) @db.Uuid
  appId          String                 @db.VarChar(64)
  label          String                 @db.VarChar(128)
  description    String?                @db.VarChar(512)
  ownerContactId String                 @db.VarChar(128)
  accessMode     ReportFolderAccessMode @default(PERSONAL)
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  app            AppConfigRecord        @relation(fields: [appId], references: [id], onDelete: Cascade)
  reports        ReportDefinitionRecord[]
  shares         ReportFolderShareRecord[]

  @@index([appId, label])
  @@index([appId, ownerContactId])
  @@map("report_folders")
}

model ReportFolderShareRecord {
  id          String                 @id @default(uuid()) @db.Uuid
  folderId    String                 @db.Uuid
  subjectType ReportShareSubjectType
  subjectId   String                 @db.VarChar(128)
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  folder      ReportFolderRecord     @relation(fields: [folderId], references: [id], onDelete: Cascade)

  @@unique([folderId, subjectType, subjectId])
  @@index([folderId])
  @@index([subjectType, subjectId])
  @@map("report_folder_shares")
}

model ReportDefinitionRecord {
  id             String              @id @default(uuid()) @db.Uuid
  appId          String              @db.VarChar(64)
  folderId       String              @db.Uuid
  label          String              @db.VarChar(128)
  description    String?             @db.VarChar(512)
  ownerContactId String              @db.VarChar(128)
  objectApiName  String              @db.VarChar(128)
  columnsJson    Json
  filtersJson    Json
  groupingsJson  Json
  sortJson       Json
  pageSize       Int                 @default(50)
  shareMode      ReportShareMode     @default(INHERIT)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  app            AppConfigRecord     @relation(fields: [appId], references: [id], onDelete: Cascade)
  folder         ReportFolderRecord  @relation(fields: [folderId], references: [id], onDelete: Cascade)
  sourceDashboards DashboardDefinitionRecord[]
  shares         ReportDefinitionShareRecord[]

  @@index([appId, folderId, label])
  @@index([appId, ownerContactId])
  @@map("report_definitions")
}

model ReportDefinitionShareRecord {
  id          String                 @id @default(uuid()) @db.Uuid
  reportId    String                 @db.Uuid
  subjectType ReportShareSubjectType
  subjectId   String                 @db.VarChar(128)
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  report      ReportDefinitionRecord @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@unique([reportId, subjectType, subjectId])
  @@index([reportId])
  @@index([subjectType, subjectId])
  @@map("report_definition_shares")
}

model DashboardFolderRecord {
  id             String                 @id @default(uuid()) @db.Uuid
  appId          String                 @db.VarChar(64)
  label          String                 @db.VarChar(128)
  description    String?                @db.VarChar(512)
  ownerContactId String                 @db.VarChar(128)
  accessMode     ReportFolderAccessMode @default(PERSONAL)
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  app            AppConfigRecord        @relation(fields: [appId], references: [id], onDelete: Cascade)
  dashboards     DashboardDefinitionRecord[]
  shares         DashboardFolderShareRecord[]

  @@index([appId, label])
  @@index([appId, ownerContactId])
  @@map("dashboard_folders")
}

model DashboardFolderShareRecord {
  id          String                 @id @default(uuid()) @db.Uuid
  folderId    String                 @db.Uuid
  subjectType ReportShareSubjectType
  subjectId   String                 @db.VarChar(128)
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  folder      DashboardFolderRecord  @relation(fields: [folderId], references: [id], onDelete: Cascade)

  @@unique([folderId, subjectType, subjectId])
  @@index([folderId])
  @@index([subjectType, subjectId])
  @@map("dashboard_folder_shares")
}

model DashboardDefinitionRecord {
  id             String                       @id @default(uuid()) @db.Uuid
  appId          String                       @db.VarChar(64)
  folderId       String                       @db.Uuid
  sourceReportId String                       @db.Uuid
  label          String                       @db.VarChar(128)
  description    String?                      @db.VarChar(512)
  ownerContactId String                       @db.VarChar(128)
  filtersJson    Json
  widgetsJson    Json
  layoutJson     Json
  shareMode      ReportShareMode              @default(INHERIT)
  createdAt      DateTime                     @default(now())
  updatedAt      DateTime                     @updatedAt
  app            AppConfigRecord              @relation(fields: [appId], references: [id], onDelete: Cascade)
  folder         DashboardFolderRecord        @relation(fields: [folderId], references: [id], onDelete: Cascade)
  sourceReport   ReportDefinitionRecord       @relation(fields: [sourceReportId], references: [id], onDelete: Restrict)
  shares         DashboardDefinitionShareRecord[]

  @@index([appId, folderId, label])
  @@index([appId, ownerContactId])
  @@index([appId, sourceReportId])
  @@map("dashboard_definitions")
}

model DashboardDefinitionShareRecord {
  id          String                    @id @default(uuid()) @db.Uuid
  dashboardId String                    @db.Uuid
  subjectType ReportShareSubjectType
  subjectId   String                    @db.VarChar(128)
  createdAt   DateTime                  @default(now())
  updatedAt   DateTime                  @updatedAt
  dashboard   DashboardDefinitionRecord @relation(fields: [dashboardId], references: [id], onDelete: Cascade)

  @@unique([dashboardId, subjectType, subjectId])
  @@index([dashboardId])
  @@index([subjectType, subjectId])
  @@map("dashboard_definition_shares")
}
