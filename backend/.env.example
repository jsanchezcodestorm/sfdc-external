NODE_ENV=development
PORT=3000
FRONTEND_ORIGINS=http://localhost:5173

# Auth
GOOGLE_CLIENT_ID=
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN_SECONDS=3600
SETUP_SECRETS_KEY=

# ACL
ACL_CONFIG_PATH=

# Salesforce
SALESFORCE_DESCRIBE_CACHE_TTL_MS=21600000
SALESFORCE_DESCRIBE_STALE_WHILE_REVALIDATE_MS=21600000
ENABLE_RAW_SALESFORCE_QUERY=false

# PostgreSQL + Prisma
DATABASE_URL=postgresql://app_rw:app_rw@localhost:5432/sfdc_external?schema=public
SHADOW_DATABASE_URL=postgresql://app_rw:app_rw@localhost:5432/sfdc_external_shadow?schema=public

# Visibility
VISIBILITY_BOOTSTRAP_ALLOW=false
VISIBILITY_CACHE_TTL_SECONDS=300
VISIBILITY_AUDIT_ENABLED=true
VISIBILITY_POLICY_PROPAGATION_TARGET_SECONDS=30
VISIBILITY_POLICY_PROPAGATION_HARD_LIMIT_SECONDS=120
VISIBILITY_AUDIT_RETENTION_DAYS=180
VISIBILITY_AUDIT_AGGREGATE_RETENTION_MONTHS=24
